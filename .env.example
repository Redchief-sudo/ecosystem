# =============================================================================
# ENVIRONMENT CONFIGURATION TEMPLATE
# =============================================================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control
# =============================================================================

# =============================================================================
# CORE SETTINGS
# =============================================================================
# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Environment: development, staging, production
ENVIRONMENT=development

# =============================================================================
# TRADING MODE
# =============================================================================
# Trading mode: paper (default, safe) or live (real money)
# IMPORTANT: Always start with paper mode!
TRADING_MODE=paper

# =============================================================================
# BLOCKCHAIN NETWORKS (RPC URLs)
# =============================================================================
# Get free RPC URLs from services like:
# - Infura: https://infura.io
# - Alchemy: https://alchemy.com
# - Ankr: https://ankr.com
# - QuickNode: https://quicknode.com

# Ethereum Mainnet
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ETH_RPC_KEY

# Binance Smart Chain
BSC_RPC_URL=https://bsc-dataseed.binance.org

# Polygon
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_POLYGON_RPC_KEY

# Arbitrum
ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_ARBITRUM_RPC_KEY

# Optimism
OPTIMISM_RPC_URL=https://opt-mainnet.g.alchemy.com/v2/YOUR_OPTIMISM_RPC_KEY

# Avalanche
AVALANCHE_RPC_URLhttps://api.avax.network/ext/bc/C/rpc

# Fantom
FANTOM_RPC_URL=https://rpc.fantom.network

# Cronos
CRONOS_RPC_URL=https://evm.cronos.org

# Aurora
AURORA_RPC_URL=https://mainnet.aurora.dev

# Harmony One
HARMONY_RPC_URL=https://api.harmony.one

# =============================================================================
# API KEYS (Blockchain Explorers)
# =============================================================================
# Get free API keys from:
# - Etherscan: https://etherscan.io/apis
# - BscScan: https://bscscan.com/apis
# - PolygonScan: https://polygonscan.com/apis
# - SnowTrace: https://snowtrace.io/apis
# - ArbiScan: https://arbiscan.io/apis

ETHERSCAN_API_KEY=your_etherscan_api_key
BSCSCAN_API_KEY=your_bscscan_api_key
POLYGONSCAN_API_KEY=your_polygonscan_api_key
SNOWTRACE_API_KEY=your_snowtrace_api_key
ARBISCAN_API_KEY=your_arbiscan_api_key

# =============================================================================
# WALLET CONFIGURATION
# =============================================================================
# Your trading wallet private key (with 0x prefix)
# WARNING: Never share this key or commit it to version control!
PRIVATE_KEY=0x0000000000000000000000000000000000000000

# Wallet address (optional, for display purposes)
WALLET_ADDRESS=0x0000000000000000000000000000000000000000

# =============================================================================
# TELEGRAM NOTIFICATIONS (Optional)
# =============================================================================
# Get bot token from @BotFather on Telegram
# Get chat ID from @userinfobot on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# =============================================================================
# TRADING CONFIGURATION
# =============================================================================
# Maximum position size as percentage of portfolio (0.01 = 1%)
MAX_POSITION_SIZE=0.10

# Risk per trade as percentage (0.02 = 2%)
RISK_PER_TRADE=0.02

# Maximum open trades
MAX_OPEN_TRADES=5

# =============================================================================
# OWNERSHIP & LICENSING (Optional)
# =============================================================================
# License key for ownership verification (if required)
LICENSE_KEY=your_license_key_here

# Dev bypass for ownership checks (DO NOT set to true in production!)
OWNERSHIP_BYPASS=false

# =============================================================================
# DATABASE (Optional)
# =============================================================================
# Custom database path (default: sqlite://data/trading_bot.db)
# DATABASE_URL=sqlite:///data/trading_bot.db

# =============================================================================
# MONITORING (Optional)
# =============================================================================
# Prometheus metrics port (default: 8000)
METRICS_PORT=8000

# Health check interval in seconds (default: 60)
HEALTH_CHECK_INTERVAL=60

