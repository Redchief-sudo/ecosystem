import asyncio

import pytest

from core.task_manager import task_manager


@pytest.mark.asyncio
async def test_valid_and_invalid_task_ids():
    # Valid id should succeed
    async def short_job():
        await asyncio.sleep(0.01)
        return True

    t = task_manager.create_engine_task(short_job(), "engine.valid_test")
    assert t is not None

    # Invalid ids should raise or fail gracefully
    try:
        task_manager.create_engine_task(short_job(), "invalidTask")
    except ValueError:
        pass  # Expected

    try:
        task_manager.create_engine_task(short_job, "bad-id-withoutdot")
    except ValueError:
        pass  # Expected

    # Cleanup
    task_manager.cancel_all()
