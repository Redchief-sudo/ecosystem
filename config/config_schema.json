{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Trading Bot Configuration",
  "description": "Schema for the trading bot configuration",
  "type": "object",
  "required": ["version", "environment", "wallets", "networks"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Configuration version in semver format"
    },
    "environment": {
      "type": "string",
      "enum": ["development", "staging", "production"],
      "default": "development"
    },
    "log_level": {
      "type": "string",
      "enum": ["DEBUG", "INFO", "WARNING", "ERROR", "CRITICAL"],
      "default": "INFO"
    },
    "wallets": {
      "type": "object",
      "required": ["executor"],
      "properties": {
        "executor": {
          "type": "object",
          "required": ["wallet_address"],
          "properties": {
            "wallet_address": {
              "type": "string",
              "pattern": "^0x[a-fA-F0-9]{40}$",
              "description": "Ethereum-compatible wallet address"
            },
            "private_key": {
              "type": "string",
              "description": "Wallet private key (should be loaded from env vars)",
              "default": ""
            }
          }
        }
      }
    },
    "networks": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["chain_id", "rpc", "wrapped_native"],
        "properties": {
          "chain_id": {"type": "integer"},
          "type": {"type": "string", "enum": ["mainnet", "testnet", "l2", "sidechain"]},
          "native_currency": {"type": "string"},
          "rpc": {"type": "string", "format": "uri"},
          "block_explorer": {"type": "string", "format": "uri"},
          "wrapped_native": {"type": "string", "pattern": "^0x[a-fA-F0-9]{40}$"},
          "router_v2": {"type": "string", "pattern": "^0x[a-fA-F0-9]{40}$"},
          "router_v3": {"type": "string", "pattern": "^0x[a-fA-F0-9]{40}$"},
          "factory_v2": {"type": "string", "pattern": "^0x[a-fA-F0-9]{40}$"},
          "multicall": {"type": "string", "pattern": "^0x[a-fA-F0-9]{40}$"},
          "enabled": {"type": "boolean", "default": true},
          "min_gas_price": {"type": "number", "minimum": 0},
          "max_gas_price": {"type": "number", "minimum": 0}
        }
      }
    },
    "scanners": {
      "type": "object",
      "properties": {
        "default": {
          "type": "object",
          "properties": {
            "min_liquidity": {"type": "number", "minimum": 0},
            "min_volume": {"type": "number", "minimum": 0},
            "max_block_lag": {"type": "integer", "minimum": 1},
            "max_workers": {"type": "integer", "minimum": 1},
            "rpc_timeout": {"type": "integer", "minimum": 1}
          }
        },
        "onchain_scanner": {"$ref": "#/properties/scanners/properties/default"},
        "hybrid_scanner": {"$ref": "#/properties/scanners/properties/default"},
        "ai_discovery_scanner": {"$ref": "#/properties/scanners/properties/default"}
      }
    },
    "ai": {
      "type": "object",
      "properties": {
        "min_confidence": {"type": "number", "minimum": 0, "maximum": 1, "default": 0.55},
        "scoring": {
          "type": "object",
          "properties": {
            "weights": {
              "type": "object",
              "properties": {
                "liquidity": {"type": "number", "minimum": 0, "maximum": 1},
                "volatility": {"type": "number", "minimum": 0, "maximum": 1},
                "volume": {"type": "number", "minimum": 0, "maximum": 1},
                "momentum": {"type": "number", "minimum": 0, "maximum": 1},
                "sentiment": {"type": "number", "minimum": 0, "maximum": 1},
                "market_cap": {"type": "number", "minimum": 0, "maximum": 1}
              },
              "additionalProperties": false
            },
            "cache_ttl": {"type": "integer", "minimum": 1, "default": 300}
          }
        },
        "models": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "path": {"type": "string"},
              "input_features": {"type": "array", "items": {"type": "string"}},
              "output_features": {"type": "array", "items": {"type": "string"}},
              "batch_size": {"type": "integer", "minimum": 1, "default": 32}
            },
            "required": ["path", "input_features", "output_features"]
          }
        }
      }
    },
    "strategies": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "enabled": {"type": "boolean", "default": true},
          "risk_per_trade": {"type": "number", "minimum": 0, "maximum": 1},
          "max_position_size": {"type": "number", "minimum": 0, "maximum": 1},
          "take_profit": {"type": "number", "minimum": 0},
          "stop_loss": {"type": "number", "maximum": 0},
          "max_slippage": {"type": "number", "minimum": 0, "maximum": 1}
        },
        "required": ["risk_per_trade", "max_position_size"]
      }
    },
    "api_keys": {
      "type": "object",
      "properties": {
        "coinmarketcap": {"type": "string"},
        "etherscan": {"type": "string"},
        "bscscan": {"type": "string"}
      },
      "additionalProperties": {"type": "string"}
    }
  },
  "additionalProperties": true
}
