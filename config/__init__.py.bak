"""Configuration management module."""

import os
import yaml
import logging
from typing import Dict, Any, Optional, Union
from pathlib import Path
from dotenv import load_dotenv

# Load environment variables from .env file
load_dotenv()

logger = logging.getLogger(__name__)

class ConfigLoader:
    """Loads and manages configuration from multiple YAML files."""
    
    def __init__(self, config_dir: Optional[str] = None):
        """Initialize the config loader.
        
        Args:
            config_dir: Path to the configuration directory
        """
        self._config: Dict[str, Any] = {}
        self._config_dir = Path(config_dir) if config_dir else Path(__file__).parent
        self._load_all_configs()
        self._init_network_manager()
    
    def _load_all_configs(self) -> None:
        """Load all configuration files from the config directory."""
        config_files = [
            'scanner_config.yaml', 
            'trading_config.yaml',
            'strategies.yaml',
            'networks.yaml'
        ]
        
        for config_file in config_files:
            file_path = self._config_dir / config_file
            if file_path.exists():
                try:
                    with open(file_path, 'r') as f:
                        config_data = yaml.safe_load(f)
                        if config_data:
                            self._config = self._deep_merge(self._config, config_data)
                            logger.debug(f"Loaded config from {config_file}")
                except Exception as e:
                    logger.error(f"Failed to load config from {config_file}: {e}")
            else:
                logger.debug(f"Config file not found: {config_file}")
    
    def _deep_merge(self, base: Dict[str, Any], update: Dict[str, Any]) -> Dict[str, Any]:
        """Deep merge two dictionaries."""
        result = base.copy()
        for key, value in update.items():
            if key in result and isinstance(result[key], dict) and isinstance(value, dict):
                result[key] = self._deep_merge(result[key], value)
            else:
                result[key] = value
        return result
    
    def _init_network_manager(self) -> None:
        """Initialize network manager with configuration."""
        from network import NetworkManager
        try:
            self.network_manager = NetworkManager(self._config)
            logger.info("Network manager initialized successfully")
        except Exception as e:
            logger.error(f"Failed to initialize network manager: {e}")
            self.network_manager = None
    
    @property
    def config(self) -> Dict[str, Any]:
        """Get the loaded configuration."""
        return self._config
    
    def get(self, key: str, default: Any = None) -> Any:
        """Get a configuration value by key."""
        return self._config.get(key, default)
    
    def set(self, key: str, value: Any) -> None:
        """Set a configuration value."""
        self._config[key] = value

# Global config instance
_config_instance: Optional[ConfigLoader] = None

def get_config(config_dir: Optional[str] = None) -> ConfigLoader:
    """Get the singleton config instance."""
    global _config_instance
    if _config_instance is None:
        _config_instance = ConfigLoader(config_dir)
    return _config_instance

# For backward compatibility
config = get_config()
